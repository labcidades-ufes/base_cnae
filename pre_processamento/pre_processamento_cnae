#!/usr/bin/env Rscript
# ==============================================================================
# PRÉ-PROCESSAMENTO — BASE CNAE (Silver)
# Lê bronze, normaliza strings, remove cabeçalhos residuais e valida formatos.
# Entrada:  bronze/base_cnae/raw_cnae_YYYYMMDD.parquet
# Saída:    silver/base_cnae/silver_cnae_YYYYMMDD.parquet
# ==============================================================================
library(dplyr)
library(stringr)
library(glue)
source("utils.R")

# ------------------------------------------------------------------------------
# 1. LEITURA DO BRONZE
# ------------------------------------------------------------------------------
read_from_minio_duckdb <- function() {
  cat("[PRE_PROCESSAMENTO] Lendo bronze...\n")
  tryCatch({
    arquivos <- list_parquet_files_in_minio("bronze/base_cnae/")
    if (length(arquivos) == 0) stop("Nenhum arquivo bronze encontrado.")
    caminho <- sub(sprintf("^s3://%s/", Sys.getenv("MINIO_BUCKET", "airflow")), "",
                   sort(arquivos, decreasing = TRUE)[1])
    cat(glue("[PRE_PROCESSAMENTO] Lendo: {caminho}\n"))
    read_parquet_from_minio(caminho)
  }, error = function(e) {
    cat("[PRE_PROCESSAMENTO] Erro ao ler bronze:", conditionMessage(e), "\n")
    quit(status = 1)
  })
}

# ------------------------------------------------------------------------------
# 2. PRÉ-PROCESSAMENTO + VALIDAÇÕES
# ------------------------------------------------------------------------------
process_data <- function(data) {
  tryCatch({
    n_entrada <- nrow(data)
    cat(glue("[PRE_PROCESSAMENTO] {n_entrada} linhas recebidas do bronze.\n"))

    registros <- as_tibble(data) |>
      # Normaliza strings: trim e converte vazias em NA
      mutate(across(c(c1, c2, c3, c4, c5, c6), ~ dplyr::na_if(trimws(.x), ""))) |>
      mutate(
        versao_label  = as.character(versao_label),
        classificacao = as.character(classificacao),
        data_coleta   = as.character(data_coleta)
      )

    # --- Validação 1: Remove linhas de cabeçalho residual ---
    # Linhas onde c5 (subclasse) contém texto descritivo em vez de código numérico
    # Ex: "Subclasse", "SUBCLASSE", "Código" que passam pelo filtro de leitura
    n_antes <- nrow(registros)
    registros <- registros |>
      filter(
        is.na(c5) |
        !str_detect(c5, regex("^(sub|cod|clas|denom|descri|estrut)", ignore_case = TRUE))
      )
    n_removidos_cabecalho <- n_antes - nrow(registros)
    if (n_removidos_cabecalho > 0) {
      cat(glue("[PRE_PROCESSAMENTO] {n_removidos_cabecalho} linhas de cabeçalho residual removidas.\n"))
    }

    # --- Validação 2: Formato do cod_subclasse (versões com subclasse) ---
    # Padrão IBGE esperado: NNNN-N/NN  ex: 4711-3/01
    # Apenas para registros onde c5 não é NA
    com_subclasse <- registros |> filter(!is.na(c5))
    formato_invalido <- com_subclasse |>
      filter(!str_detect(c5, "^\\d{4}-\\d/\\d{2}$"))

    if (nrow(formato_invalido) > 0) {
      cat(glue("[PRE_PROCESSAMENTO] AVISO: {nrow(formato_invalido)} registros com cod_subclasse fora do padrão IBGE (NNNN-N/NN):\n"))
      formato_invalido |>
        select(classificacao, c5) |>
        distinct() |>
        head(10) |>
        print()
    } else {
      cat("[PRE_PROCESSAMENTO] Validação de formato cod_subclasse: OK\n")
    }

    # --- Validação 3: Versões esperadas presentes ---
    versoes_encontradas <- n_distinct(registros$versao_label)
    cat(glue("[PRE_PROCESSAMENTO] {versoes_encontradas} versões CNAE no bronze.\n"))

    # --- Resumo final ---
    n_saida <- nrow(registros)
    cat(glue("[PRE_PROCESSAMENTO] {n_saida} linhas após pré-processamento (removidas: {n_entrada - n_saida}).\n"))

    registros
  }, error = function(e) {
    cat("[PRE_PROCESSAMENTO] Erro:", conditionMessage(e), "\n")
    quit(status = 1)
  })
}

# ------------------------------------------------------------------------------
# 3. SALVAR SILVER
# ------------------------------------------------------------------------------
save_to_minio_duckdb <- function(data) {
  tryCatch({
    filepath <- sprintf("silver/base_cnae/silver_cnae_%s.parquet", format(Sys.time(), "%Y%m%d"))
    cat(glue("[PRE_PROCESSAMENTO] Salvando em: {filepath}\n"))
    write_parquet_to_minio(data, filepath)
    filepath
  }, error = function(e) {
    cat("[PRE_PROCESSAMENTO] Erro ao salvar:", conditionMessage(e), "\n")
    quit(status = 1)
  })
}

bronze <- read_from_minio_duckdb()
silver <- process_data(bronze)
saida  <- save_to_minio_duckdb(silver)
cat("[PRE_PROCESSAMENTO] Finalizado:", saida, "\n")
